# orrith environment variables
# Copy to .env (gitignored) and fill in.
# Or use `op inject -i .env.example -o .env` if you store secrets in 1Password.

# GitHub PAT (optional). Without it, public API rate limit is 60/h. With PAT: 5000/h.
# Required scope: public_repo (for public repo metrics) or repo (for private)
GITHUB_TOKEN=

# Cloudflare account-level metrics (workers / r2 / d1 lists)
# Account ID: dash.cloudflare.com → right sidebar
# API Token: dash.cloudflare.com/profile/api-tokens → Create Custom Token
#   Required permissions:
#     Account > Workers Scripts > Read
#     Account > D1 > Read
#     Account > R2 > Read (Account level)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Sentry (projects + 24h unresolved issues)
# Org slug: from sentry.io URL, e.g. sentry.io/{org_slug}/
# Auth token: User Settings > Auth Tokens > Create New Token
#   Scopes: org:read, project:read, event:read
SENTRY_ORG=
SENTRY_TOKEN=

# Stripe (balance + active subs + 24h charges)
# Use a Restricted Key (sk_rk_...) with read access to:
#   Balance, Charges, Subscriptions
# Or full secret key sk_live_... / sk_test_...
STRIPE_SECRET_KEY=
